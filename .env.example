# LLM Provider Configuration
# Options: "ollama", "gemini", "openai"
LLM_PROVIDER=openai

# Default model to use
# For OpenAI: "gpt-4o-mini", "gpt-4o"
# For Ollama: "gemma3:4b", "qwen3:4b", "mistral:7b", etc.
# For Gemini: "gemini-2.5-pro", "gemini-2.5-flash", etc.
DEFAULT_MODEL=gpt-4o-mini

# OpenAI API Key (required if using OpenAI provider)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key (required if using Gemini provider)
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub token (optional, improves API rate limits)
# GITHUB_TOKEN=

# Path to the LinkedIn session file created by linkedin_scraper/samples/create_session.py
# (needed for LinkedIn profile/job imports; file is gitignored)
LINKEDIN_SESSION_PATH=linkedin_session.json
